# =============================================================================
# NARRATIVE AI - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
#
# INSTRUCTIONS:
# 1. Copy this file to .env (cp .env.example .env)
# 2. Fill in your API keys - NEVER commit .env to version control
# 3. The application will automatically load these values
#
# =============================================================================

# -----------------------------------------------------------------------------
# GEMINI LLM (REQUIRED - FREE)
# -----------------------------------------------------------------------------
# Get your FREE API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# ELEVENLABS STT/TTS (OPTIONAL - FREE tier: 10,000 chars/month)
# -----------------------------------------------------------------------------
# Get your API key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Set to 1 if free-tier key returns 401 on /user verification (STT still works)
ELEVENLABS_SKIP_KEY_VERIFY=0

# -----------------------------------------------------------------------------
# OPENAI GPT-4o-mini (OPTIONAL - Paid)
# -----------------------------------------------------------------------------
# Get your API key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
COHERE_API_KEY=your_cohere_api_key_here

# -----------------------------------------------------------------------------
# LIVEKIT (REQUIRED for real-time voice - FREE tier available)
# -----------------------------------------------------------------------------
# Get credentials: https://cloud.livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
# Token TTL in seconds (default 3600 = 1 hour). Clamped to 60–86400. Shorter = more secure for single sessions.
# LIVEKIT_TOKEN_TTL_SECONDS=3600
# Dispatch API timeout in seconds (default 8). Clamped to 1–60.
# LIVEKIT_DISPATCH_TIMEOUT_SECONDS=8
# When 1, backend returns dispatch_required and client/script should call POST /api/voice/dispatch
# with room_name so the narrative-voice agent joins the room (required if Cloud does not auto-dispatch).
LIVEKIT_EXPLICIT_DISPATCH=1

# -----------------------------------------------------------------------------
# DEV ONLY - Never set in production (rate limit is bypassed when enabled)
# -----------------------------------------------------------------------------
VOICE_DEV_SKIP_RATE_LIMIT=0

# -----------------------------------------------------------------------------
# VOICE CLIENT
# -----------------------------------------------------------------------------
VOICE_USE_LIVEKIT_STT=1
VOICE_USE_TURN_DETECTOR=0
VOICE_USE_NOISE_CANCELLATION=1
VOICE_USE_WEBRTC_VAD=0
VOICE_CLIENT_MUTE_WHILE_AGENT_SPEAKING=1
VOICE_CLIENT_MUTE_DURATION_SEC=3
VOICE_CLIENT_SILENCE_UNMUTE_MS=500

# -----------------------------------------------------------------------------
# CUSTOM MODELS
# -----------------------------------------------------------------------------
WHISPER_MODEL_PATH=./models/whisper-3-turbo-finetuned-ct2
WHISPER_SERVER_URL=http://localhost:8000
CUSTOM_TTS_SERVER_URL=http://localhost:8001

# -----------------------------------------------------------------------------
# DATABASE (Single PostgreSQL instance for all app data)
# -----------------------------------------------------------------------------
# The ONE database for everything: users, entries, embeddings, conversations,
# audio metadata, preferences, subscriptions, analytics, audit logs.
# Requires the pgvector extension for semantic search.
DATABASE_URL=postgresql://postgres.opinluwcdrnwgtlvlmvq:QqkncH8Mvq6L2GvD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres


# Pool tuning (defaults are good for most setups)
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_RECYCLE=3600  # seconds; recycle idle connections to avoid stale sockets
DATABASE_ECHO_SQL=false

# -----------------------------------------------------------------------------
# REDIS (Ephemeral cache -- NOT a database)
# -----------------------------------------------------------------------------
# Used for: rate limiting, search cache (30min), preference cache (1day),
# session state (24h), refresh-token JTI tracking.  Data here is expendable.
REDIS_URL=redis://localhost:6379/0

# Cache TTLs (seconds)
CACHE_TTL_SEARCH=1800
CACHE_TTL_PREFERENCES=86400
CACHE_TTL_SESSION=86400

# Rate Limiting tuning
# FAIL_CLOSED=true prevents requests if Redis is down (more secure for production)
RATE_LIMIT_FAIL_CLOSED=false
# Optional: persist local rate limits to file if Redis is down
# RATE_LIMIT_PERSISTENT_STORAGE=/app/data/rate_limits.json

# -----------------------------------------------------------------------------
# VECTOR SEARCH (pgvector HNSW tuning)
# -----------------------------------------------------------------------------
VECTOR_DIMENSION=768
VECTOR_HNSW_EF_SEARCH=40

# -----------------------------------------------------------------------------
# JWT AUTHENTICATION
# -----------------------------------------------------------------------------
# PRODUCTION: Generate a strong secret with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# NEVER use the default value in production.
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# GOOGLE SIGN-IN (POST /api/auth/google)
# -----------------------------------------------------------------------------
# OAuth 2.0 client ID used to verify the `id_token` audience. The token's `aud`
# claim MUST equal this. For multiple platforms (iOS/Android/web) provide a
# comma-separated list. Get it from Google Cloud Console > Credentials.
# REQUIRED for live Google sign-in; without it /api/auth/google returns 401.
GOOGLE_CLIENT_ID=

# -----------------------------------------------------------------------------
# PASSWORD RESET E-MAIL (POST /api/auth/forgot-password, /reset-password)
# -----------------------------------------------------------------------------
# Backend selector: console (default) | smtp | sendgrid.
# "console" needs ZERO config and logs the reset link/token at INFO (demoable).
EMAIL_PROVIDER=console
# From address used on outgoing mail.
EMAIL_FROM=no-reply@narrative.ai
# Deep link the app handles for resets; token is appended as ?token=...
# If unset, the raw token is delivered instead of a link.
# APP_PASSWORD_RESET_URL=https://app.narrative-ai.com/reset-password
# Reset token lifetime in seconds (default 3600 = 1 hour).
# PASSWORD_RESET_TTL_SECONDS=3600
#
# --- SendGrid (when EMAIL_PROVIDER=sendgrid) ---
# SENDGRID_API_KEY=
#
# --- SMTP (when EMAIL_PROVIDER=smtp) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true

# -----------------------------------------------------------------------------
# EXPO PUSH NOTIFICATIONS (POST /api/notifications/register)
# -----------------------------------------------------------------------------
# Optional. Only required if your Expo project enabled "Enhanced Security for
# Push Notifications"; sent as a Bearer token to the Expo Push API.
# EXPO_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# ENVIRONMENT
# -----------------------------------------------------------------------------
# Set to "production" for production deployments.
# In production mode:
#   - CORS_ALLOWED_ORIGINS is REQUIRED (app refuses to start without it)
#   - Rate limiter returns 503 if Redis is unavailable (fail closed)
#   - Internal error details are suppressed in API responses
#   - Alembic migration failures are FATAL (container exits)
ENV=development

# -----------------------------------------------------------------------------
# CORS (Required in production)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins.
# Example: CORS_ALLOWED_ORIGINS=https://app.narrative-ai.com,https://admin.narrative-ai.com
# In development, if unset, defaults to allowing all origins ("*").
CORS_ALLOWED_ORIGINS=

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
# Valid levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO. Use DEBUG for local development troubleshooting.
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# DOCKER-COMPOSE SECRETS
# -----------------------------------------------------------------------------
# Used by docker-compose.yml for PostgreSQL password.
# PRODUCTION: Generate a strong password with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# In development the default 'narrative_dev_password' is used.
POSTGRES_PASSWORD=narrative_dev_password

# -----------------------------------------------------------------------------
# AUDIT (Optional -- uses main DATABASE_URL if not set)
# -----------------------------------------------------------------------------
AUDIT_DATABASE_URL=
AUDIT_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# LEGACY -- deprecated, prefer DATABASE_URL above
# -----------------------------------------------------------------------------
# LLM_CONVERSATION_DATABASE_URL=
# VOICE_CONVERSATION_DATABASE_URL=

# -----------------------------------------------------------------------------
# RAG / INPUT PROCESSING / OCR (from rag_input_proc)
# -----------------------------------------------------------------------------
# Google Cloud Vision API (OCR)
# GOOGLE_VISION_API_KEY=

# Google API Key (Gemini Vision / RAG)
# GOOGLE_API_KEY=

# Cohere API Key (RAG Multilingual Embeddings)
# Get your API key: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_api_key_here

# Ollama (local VLM)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2-vl:2b
# OLLAMA_CLOUD_API_KEY=your_ollama_cloud_api_key_here

# LLM provider overrides
LLM_PRIMARY_PROVIDER=ollama
LLM_FALLBACK_PROVIDERS=ollama

# -----------------------------------------------------------------------------
# WEB INTELLIGENCE ENGINE
# -----------------------------------------------------------------------------
WEB_INTEL_ENABLED=1
WEB_INTEL_MODE=auto
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_CX=

# Kaggle OCR (Remote) -- REQUIRED in production if using remote OCR
# KAGGLE_OCR_URL=https://your-ngrok-or-server.app/ocr

# -----------------------------------------------------------------------------
# PRODUCTION DEPLOY (OCI) - Required when ENV=production and deploying to OCI
# -----------------------------------------------------------------------------
# OCI region. Used by validate_env.py for production.
# Frankfurt, Germany (Always Free):
OCI_REGION=eu-frankfurt-1

# -----------------------------------------------------------------------------
# PRODUCTION DEPLOY (DigitalOcean) - Required when using docker-compose.do.yml
# -----------------------------------------------------------------------------
# Public hostname served by Caddy (auto-HTTPS via Let's Encrypt).
# Use the dashed sslip.io form so we don't need a paid wildcard cert:
#   narrative-<DROPLET_IP_WITH_DASHES>.sslip.io
NARRATIVE_HOSTNAME=

# Image source for docker-compose.do.yml. Defaults to GHCR for the
# repository owner; override locally to test a different tag.
#   NARRATIVE_IMAGE=ghcr.io/<owner>/narrative-ai:<sha-or-latest>
NARRATIVE_IMAGE=
GHCR_OWNER=
IMAGE_TAG=latest
